import unittest

# 1. The code we want to test (e.g., a simple Calculator class)
class Calculator:
    def add(self, a, b):
        return a + b

    def divide(self, a, b):
        if b == 0:
            raise ValueError("Cannot divide by zero!")
        return a / b

# 2. The test code
class TestCalculator(unittest.TestCase):

    # Set up method runs before every test
    def setUp(self):
        self.calc = Calculator()

    # Test the addition method
    def test_add_success(self):
        # Arrange: Inputs
        x, y = 5, 3
        
        # Act: Run the code
        result = self.calc.add(x, y)
        
        # Assert: Verify the outcome
        self.assertEqual(result, 8)

    # Test handling of errors
    def test_divide_by_zero(self):
        # Arrange & Act: Check if exception is raised
        with self.assertRaises(ValueError):
            self.calc.divide(10, 0)

# Run the tests directly from the script
if __name__ == '__main__':
    unittest.main()

